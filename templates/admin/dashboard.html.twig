{% extends 'base.html.twig' %}

{% block title %}CNB Operaciones{% endblock %}

{% block body %}
    <header class="mb-4 d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
            <h1 class="h3 mb-1">Panel operativo</h1>
            <p class="text-muted mb-0">Gestión de socios, varadero, tareas, marineros y activos del club.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('admin_varadero') }}">Planificador de varadero</a>
    </header>

    <div class="row g-3">
        {% for name, resource in resources %}
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between gap-3">
                            <div>
                                <h2 class="h5">{{ resource.label }}</h2>
                                <p class="text-muted">{{ resource.description }}</p>
                            </div>
                            <span class="badge text-bg-secondary align-self-start">{{ stats[name] }}</span>
                        </div>
                        <a class="btn btn-primary" href="{{ path('admin_resource_index', {resource: name}) }}">Abrir</a>
                        {% if name == 'reservas-varadero' %}
                            <a class="btn btn-outline-primary" href="{{ path('admin_varadero') }}">Planificar</a>
                        {% else %}
                            <a class="btn btn-outline-primary" href="{{ path('admin_resource_new', {resource: name}) }}">Nuevo</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}
