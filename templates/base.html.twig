<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Club Náutico Bariloche{% endblock %}</title>
        <link rel="icon" type="image/jpeg" href="/images/cnb_logo-32.jpg">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="/css/cnb.css" rel="stylesheet">
        <style>
            :root {
                --cnb-navy: #002147;
                --cnb-navy-dark: #001428;
            }

            .cnb-header {
                background: #fff;
                border-bottom: 2px solid #c0c0c0;
                padding: 0.75rem 0;
            }

            .cnb-brand {
                display: flex;
                align-items: center;
                gap: 1rem;
                text-decoration: none;
            }

            .cnb-brand:hover {
                text-decoration: none;
            }

            .cnb-brand-logo {
                width: 72px;
                height: 72px;
                object-fit: cover;
                border-radius: 50%;
                border: 2px solid #c0c0c0;
                flex-shrink: 0;
            }

            .cnb-brand-title {
                color: #002147;
                font-size: 1.5rem;
                font-weight: 700;
                line-height: 1.2;
                letter-spacing: 0.01em;
            }

            .cnb-header .nav-link {
                color: #002147;
                font-weight: 500;
            }

            .cnb-header .nav-link:hover,
            .cnb-header .nav-link:focus {
                color: #001428;
            }

            .btn-primary {
                --bs-btn-bg: #002147;
                --bs-btn-border-color: #002147;
                --bs-btn-hover-bg: #001428;
                --bs-btn-hover-border-color: #001428;
                --bs-btn-active-bg: #001428;
                --bs-btn-active-border-color: #001428;
                background-color: #002147;
                border-color: #002147;
            }

            .btn-primary:hover,
            .btn-primary:focus {
                background-color: #001428;
                border-color: #001428;
            }

            .btn-outline-primary {
                --bs-btn-color: #002147;
                --bs-btn-border-color: #002147;
                --bs-btn-hover-bg: #002147;
                --bs-btn-hover-border-color: #002147;
                --bs-btn-active-bg: #001428;
                --bs-btn-active-border-color: #001428;
                color: #002147;
                border-color: #002147;
            }

            .btn-outline-primary:hover,
            .btn-outline-primary:focus {
                background-color: #002147;
                border-color: #002147;
                color: #fff;
            }
        </style>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <header class="cnb-header mb-4">
            <div class="container-fluid d-flex align-items-center justify-content-between gap-3">
                <a class="cnb-brand" href="{{ path('admin_dashboard') }}">
                    <img
                        class="cnb-brand-logo"
                        src="/images/cnb_logo-96.jpg"
                        alt="Club Náutico Bariloche"
                        width="72"
                        height="72"
                    >
                    <span class="cnb-brand-title">Club Náutico Bariloche</span>
                </a>
                <nav class="nav">
                    <a class="nav-link" href="{{ path('admin_dashboard') }}">Admin</a>
                    <a class="nav-link" href="/api/health">API</a>
                </nav>
            </div>
        </header>
        <main class="container-fluid pb-5">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
